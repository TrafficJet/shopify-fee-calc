---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noWebAppSchema?: boolean;
}
const { title, description, canonicalUrl, ogImage, noWebAppSchema } = Astro.props;
const canon = canonicalUrl || Astro.url.href;
const finalOgImage = ogImage || 'https://shopify-fee-calc.com/og-default.png';
const GA_ID = 'G-3LG69MHKYE';
const webAppSchemaJson = JSON.stringify({"@context":"https://schema.org","@type":"WebApplication","name":"Shopify Fee Calculator","url":"https://shopify-fee-calc.com/","description":"Free Shopify fee calculator. Estimate transaction fees, payment processing costs, and profit margins for your Shopify store.","applicationCategory":"UtilityApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}});
const _path = new URL(canon).pathname;
const breadcrumbJson = _path !== '/' ? JSON.stringify({"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"ShopifyCalc","item":"https://shopify-fee-calc.com/"},{"@type":"ListItem","position":2,"name":title.split(' — ')[0].split(' | ')[0].trim(),"item":canon}]}) : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#2563eb" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canon} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canon} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta property="og:image" content={finalOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:image" content={finalOgImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />
  <slot name="head" />
  {!noWebAppSchema && <script type="application/ld+json" set:html={webAppSchemaJson} />}
  {breadcrumbJson && <script type="application/ld+json" set:html={breadcrumbJson} />}
  <!-- Anti-FOUC: apply dark mode before paint -->
  <script is:inline>
    (function() {
      var saved = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="bg-white text-gray-900 font-sans dark:bg-gray-950 dark:text-gray-100 transition-colors duration-200">
  <header class="border-b border-gray-200 dark:border-gray-800 px-6 py-4 bg-white dark:bg-gray-950">
    <nav class="max-w-5xl mx-auto flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-blue-700 dark:text-blue-400">ShopifyCalc</a>
      <ul class="flex gap-5 text-sm text-gray-600 dark:text-gray-400 flex-wrap items-center">
        <li><a href="/shopify-profit-calculator/" class="hover:text-blue-700 dark:hover:text-blue-400">P&amp;L Calc</a></li>
        <li><a href="/shopify-hidden-fees-audit/" class="hover:text-blue-700 dark:hover:text-blue-400">Fee Audit</a></li>
        <li><a href="/breakeven-roas-calculator/" class="hover:text-blue-700 dark:hover:text-blue-400">ROAS</a></li>
        <li><a href="/shopify-plan-comparison/" class="hover:text-blue-700 dark:hover:text-blue-400">Plans</a></li>
        <li><a href="/payment-processor-compare/" class="hover:text-blue-700 dark:hover:text-blue-400">Processors</a></li>
        <li><a href="/ltv-cac-calculator/" class="hover:text-blue-700 dark:hover:text-blue-400">LTV:CAC</a></li>
        <li><a href="/blog/" class="hover:text-blue-700 dark:hover:text-blue-400">Blog</a></li>
        <li>
          <button id="theme-toggle" aria-label="Toggle dark mode"
            class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
            <svg id="icon-sun" class="hidden w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
            </svg>
            <svg id="icon-moon" class="w-5 h-5 text-gray-500 dark:text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
            </svg>
          </button>
        </li>
      </ul>
    </nav>
  </header>

  <main class="max-w-5xl mx-auto px-6 py-10">
    <slot />
  </main>

  <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-8 mt-16 text-sm text-gray-500 dark:text-gray-400 bg-white dark:bg-gray-950">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-4">
        <span>© {new Date().getFullYear()} ShopifyCalc — independent tool, not affiliated with Shopify Inc., USPS, UPS, FedEx, or DHL.</span>
        <ul class="flex gap-4 shrink-0">
          <li><a href="/privacy/" class="hover:text-blue-700 dark:hover:text-blue-400">Privacy</a></li>
          <li><a href="/terms/" class="hover:text-blue-700 dark:hover:text-blue-400">Terms</a></li>
          <li><a href="/about/" class="hover:text-blue-700 dark:hover:text-blue-400">About</a></li>
          <li class="text-gray-300 dark:text-gray-700">|</li>
          <li><a href="https://commission-calc.com/" class="hover:text-blue-700 dark:hover:text-blue-400">Commission Calc</a></li>
          <li><a href="https://app-compare.com/" class="hover:text-blue-700 dark:hover:text-blue-400">App Compare</a></li>
        </ul>
      </div>
      <p class="text-xs text-gray-400 dark:text-gray-500 leading-relaxed">
        Shipping rates shown on this site are approximate estimates based on publicly available carrier schedules and are provided for informational purposes only.
        Always verify current rates at <a href="https://www.usps.com" target="_blank" rel="noopener nofollow" class="hover:text-blue-600">usps.com</a>,
        <a href="https://www.ups.com" target="_blank" rel="noopener nofollow" class="hover:text-blue-600">ups.com</a>,
        <a href="https://www.fedex.com" target="_blank" rel="noopener nofollow" class="hover:text-blue-600">fedex.com</a>, or
        <a href="https://www.dhl.com" target="_blank" rel="noopener nofollow" class="hover:text-blue-600">dhl.com</a>
        before shipping. Shopify® is a registered trademark of Shopify Inc. UPS® is a trademark of United Parcel Service, Inc. FedEx® is a trademark of Federal Express Corp. DHL® is a trademark of Deutsche Post AG.
      </p>
    </div>
  </footer>
  <script defer src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_ID);
  </script>
  <script is:inline>
    (function() {
      var btn = document.getElementById('theme-toggle');
      var sun = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');

      function syncIcons() {
        var isDark = document.documentElement.classList.contains('dark');
        sun.classList.toggle('hidden', !isDark);
        moon.classList.toggle('hidden', isDark);
      }

      syncIcons();

      btn.addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcons();
      });
    })();
  </script>

  <!-- Exit-intent popup -->
  <div id="ei-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:1000;align-items:center;justify-content:center;padding:16px">
    <div style="background:#fff;border-radius:16px;max-width:480px;width:100%;padding:32px;position:relative;color:#111">
      <button id="ei-close" aria-label="Close" style="position:absolute;top:12px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#888;line-height:1">×</button>
      <div style="font-size:13px;font-weight:700;color:#2563eb;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">Free PDF Guide</div>
      <h2 style="margin:0 0 8px;font-size:22px;font-weight:800;line-height:1.2">Wait — get the Shopify Hidden Fees Audit before you go</h2>
      <p style="color:#555;margin:0 0 20px;font-size:14px">12-page guide: 5 hidden fees draining your margins, how to calculate each one, and exactly how to fix them. Free.</p>
      <div id="ei-form-wrap">
        <form id="ei-form" style="display:flex;gap:8px;flex-wrap:wrap">
          <input id="ei-email" type="email" placeholder="your@email.com" required autocomplete="email"
            style="flex:1;min-width:200px;border:1.5px solid #d1d5db;border-radius:8px;padding:10px 14px;font-size:14px;outline:none" />
          <button type="submit"
            style="background:#2563eb;color:#fff;font-weight:700;font-size:14px;border:none;border-radius:8px;padding:10px 20px;cursor:pointer;white-space:nowrap">
            Send me the PDF
          </button>
        </form>
        <p style="color:#9ca3af;font-size:11px;margin:8px 0 0">No spam. Unsubscribe any time.</p>
      </div>
      <div id="ei-success" style="display:none;text-align:center;padding:12px 0">
        <div style="font-size:32px;margin-bottom:8px">🎉</div>
        <p style="font-weight:700;margin:0 0 4px">Check your inbox!</p>
        <p style="color:#555;font-size:13px;margin:0">The guide is on its way. Also available here: <a href="/shopify-hidden-fees-audit-download/" style="color:#2563eb">open PDF guide →</a></p>
      </div>
      <div id="ei-error" style="display:none;color:#dc2626;font-size:13px;margin-top:8px"></div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var TRIGGER_PATHS = ['/', '/shopify-profit-calculator/', '/shopify-hidden-fees-audit/'];
      var path = window.location.pathname;
      if (!TRIGGER_PATHS.includes(path)) return;
      if (sessionStorage.getItem('ei_seen')) return;

      var overlay = document.getElementById('ei-overlay');
      var form = document.getElementById('ei-form');
      var emailInput = document.getElementById('ei-email');
      var success = document.getElementById('ei-success');
      var error = document.getElementById('ei-error');
      var triggered = false;

      function show() {
        if (triggered) return;
        triggered = true;
        sessionStorage.setItem('ei_seen', '1');
        overlay.style.display = 'flex';
      }

      function hide() {
        overlay.style.display = 'none';
      }

      document.getElementById('ei-close').addEventListener('click', hide);
      overlay.addEventListener('click', function(e) { if (e.target === overlay) hide(); });

      // Desktop: mouse leaves top 10% of viewport
      document.addEventListener('mouseleave', function(e) {
        if (e.clientY < window.innerHeight * 0.1) show();
      });

      // Mobile: scrolled past 70%
      window.addEventListener('scroll', function() {
        var scrolled = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
        if (scrolled > 0.7) show();
      }, { passive: true });

      // 30s fallback for slow readers
      setTimeout(show, 30000);

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var email = emailInput.value.trim();
        var btn = form.querySelector('button[type=submit]');
        btn.disabled = true;
        btn.textContent = 'Sending…';
        error.style.display = 'none';
        try {
          var res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, source: 'exit-intent-pdf', newsletter: true }),
          });
          if (res.ok) {
            document.getElementById('ei-form-wrap').style.display = 'none';
            success.style.display = 'block';
          } else {
            throw new Error('Server error');
          }
        } catch(err) {
          error.textContent = 'Something went wrong. Try again.';
          error.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Send me the PDF';
        }
      });
    })();
  </script>
</body>
</html>
