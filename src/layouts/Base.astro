---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
}
const { title, description, canonicalUrl } = Astro.props;
const canon = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canon} />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-3LG69MHKYE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-3LG69MHKYE');
  </script>
  <slot name="head" />
</head>
<body class="bg-white text-gray-900 font-sans">
  <header class="border-b border-gray-200 px-6 py-4">
    <nav class="max-w-5xl mx-auto flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-blue-700">ShopifyCalc</a>
      <ul class="flex gap-6 text-sm text-gray-600">
        <li><a href="/shipping-calculator" class="hover:text-blue-700">Shipping Calculator</a></li>
        <li><a href="/profit-margin" class="hover:text-blue-700">Profit Margin</a></li>
        <li><a href="/blog" class="hover:text-blue-700">Blog</a></li>
      </ul>
    </nav>
  </header>

  <main class="max-w-5xl mx-auto px-6 py-10">
    <slot />
  </main>

  <footer class="border-t border-gray-200 px-6 py-8 mt-16 text-sm text-gray-500">
    <div class="max-w-5xl mx-auto flex justify-between">
      <span>© {new Date().getFullYear()} ShopifyCalc. Not affiliated with Shopify Inc.</span>
      <ul class="flex gap-4">
        <li><a href="/privacy" class="hover:text-blue-700">Privacy</a></li>
        <li><a href="/terms" class="hover:text-blue-700">Terms</a></li>
      </ul>
    </div>
  </footer>
</body>
</html>
