---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | Shopify Fee Calculator" description="That page doesn't exist. Try our free Shopify fee and profit calculators.">
  <div class="max-w-2xl mx-auto text-center py-20 px-4">
    <p class="text-8xl font-bold text-blue-100 mb-2">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-3">Page not found</h1>
    <p class="text-gray-500 mb-10">That URL doesn't exist. Here are our most popular calculators:</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left mb-10">
      <a href="/shopify-fee-calculator/" class="block border border-blue-100 rounded-xl p-4 hover:border-blue-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Shopify Fee Calculator</div>
        <div class="text-blue-600 text-xs mt-0.5">Transaction + processing fees →</div>
      </a>
      <a href="/profit-margin/" class="block border border-blue-100 rounded-xl p-4 hover:border-blue-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Profit Margin Calculator</div>
        <div class="text-blue-600 text-xs mt-0.5">True margin after fees →</div>
      </a>
      <a href="/shipping-calculator/" class="block border border-blue-100 rounded-xl p-4 hover:border-blue-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Shipping Cost Calculator</div>
        <div class="text-blue-600 text-xs mt-0.5">Carrier rate comparison →</div>
      </a>
      <a href="/break-even/" class="block border border-blue-100 rounded-xl p-4 hover:border-blue-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Break-Even Calculator</div>
        <div class="text-blue-600 text-xs mt-0.5">Units needed to profit →</div>
      </a>
    </div>

    <div class="flex flex-wrap gap-3 justify-center text-sm">
      <a href="/" class="bg-blue-700 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-blue-800 transition">All Calculators</a>
      <a href="/blog/" class="text-blue-600 border border-blue-200 px-6 py-2.5 rounded-lg hover:bg-blue-50 transition">Blog</a>
    </div>
  </div>
</Base>
