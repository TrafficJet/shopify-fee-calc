---
import Base from '../layouts/Base.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Shopify Fee & Profit Calculator",
  "url": "https://shopify-fee-calc.com",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "8 free calculators to find hidden Shopify fees, calculate true profit margins, and compare plans. No signup required.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What fees does Shopify charge that most sellers miss?",
      "acceptedAnswer": { "@type": "Answer", "text": "The most commonly missed fees are the transaction fee (0.5–2% on orders when not using Shopify Payments), currency conversion markup (1.5%), chargeback handling fees ($15 per dispute), and third-party app costs that add up to $100–$400/month for most mid-size stores." }
    },
    {
      "@type": "Question",
      "name": "How is the Shopify profit calculator different from Shopify's own analytics?",
      "acceptedAnswer": { "@type": "Answer", "text": "Shopify Analytics shows revenue and basic gross profit. It doesn't subtract platform fees, app costs, marketing spend, or returns. The Real Profit Calculator builds a complete P&L so you see net profit, not just gross margin." }
    },
    {
      "@type": "Question",
      "name": "Are these calculators free? Do I need to create an account?",
      "acceptedAnswer": { "@type": "Answer", "text": "All 8 calculators are completely free with no signup required. Your data is processed in your browser and is never stored or shared." }
    },
    {
      "@type": "Question",
      "name": "When should I upgrade from Basic to the Shopify plan?",
      "acceptedAnswer": { "@type": "Answer", "text": "The break-even point is typically around $35,000–$40,000/month in revenue, where the lower transaction fee (1% → 0.5%) saves more than the $39 monthly plan upgrade." }
    }
  ]
});
---
<Base
  title="Shopify Fee & Profit Calculator — Find Hidden Costs, See True Margins (Free, 2026)"
  description="Find hidden Shopify fees, calculate real profit margins, and compare plans in 30 seconds. 8 free calculators — no signup, no ads."
>
  <script type="application/ld+json" slot="head" set:html={schema} />
  <script type="application/ld+json" slot="head" set:html={faqSchema} />

  <!-- Hero -->
  <section class="text-center py-10 border-b border-gray-100 dark:border-gray-800 mb-8">
    <h1 class="text-4xl font-bold mb-3">Shopify Fee & Profit Calculator</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-6">
      Find every hidden fee, calculate your true profit margin, and compare Shopify plans — in 30 seconds. No signup, no ads.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/shopify-profit-calculator/" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">Calculate Your Profit →</a>
      <a href="/shopify-hidden-fees-audit/" class="border-2 border-blue-600 text-blue-700 dark:text-blue-400 dark:border-blue-500 hover:bg-blue-50 dark:hover:bg-blue-950 px-5 py-2.5 rounded-lg text-sm font-semibold transition">Audit Your Fees →</a>
    </div>
  </section>

  <!-- 2 flagship tools -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <a href="/shopify-profit-calculator/" class="group flex flex-col border-2 border-green-400 dark:border-green-600 bg-green-50 dark:bg-green-950 rounded-xl p-6 hover:shadow-lg transition-all">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-3xl">📊</span>
        <div>
          <div class="text-xs font-semibold text-green-700 dark:text-green-400 uppercase tracking-wide">Flagship Tool</div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 group-hover:text-green-700 dark:group-hover:text-green-400 transition-colors">Real Profit Calculator</h2>
        </div>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400 flex-1">Full monthly P&amp;L — revenue minus COGS, fees, apps, marketing, and returns. Pie chart breakdown of where every dollar goes.</p>
      <div class="mt-3 text-xs font-medium text-green-700 dark:text-green-400">Try it →</div>
    </a>
    <a href="/shopify-hidden-fees-audit/" class="group flex flex-col border-2 border-orange-400 dark:border-orange-600 bg-orange-50 dark:bg-orange-950 rounded-xl p-6 hover:shadow-lg transition-all">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-3xl">🔍</span>
        <div>
          <div class="text-xs font-semibold text-orange-700 dark:text-orange-400 uppercase tracking-wide">5-Step Audit</div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 group-hover:text-orange-700 dark:group-hover:text-orange-400 transition-colors">Hidden Fees Audit Tool</h2>
        </div>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400 flex-1">Find every fee you're paying — transaction charges, apps, currency conversion, chargebacks. Full breakdown + PDF export.</p>
      <div class="mt-3 text-xs font-medium text-orange-700 dark:text-orange-400">Start audit →</div>
    </a>
  </div>

  <!-- 6 business calculators in 3-col grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <a href="/breakeven-roas-calculator/" class="group flex flex-col border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-950 rounded-xl p-5 hover:border-blue-400 dark:hover:border-blue-600 hover:shadow-md transition-all">
      <div class="text-2xl mb-2">📈</div>
      <h2 class="font-semibold text-gray-900 dark:text-gray-100 mb-1 group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors">Breakeven ROAS</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 flex-1">Minimum ROAS for profitability. Includes sensitivity table and Meta/Google/TikTok channel breakdown.</p>
    </a>
    <a href="/shopify-plan-comparison/" class="group flex flex-col border border-indigo-200 dark:border-indigo-800 bg-indigo-50 dark:bg-indigo-950 rounded-xl p-5 hover:border-indigo-400 dark:hover:border-indigo-600 hover:shadow-md transition-all">
      <div class="text-2xl mb-2">💳</div>
      <h2 class="font-semibold text-gray-900 dark:text-gray-100 mb-1 group-hover:text-indigo-700 dark:group-hover:text-indigo-400 transition-colors">Plan Comparison</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 flex-1">Basic vs Shopify vs Advanced vs Plus — total monthly cost at your revenue. Exact upgrade break-even points.</p>
    </a>
    <a href="/payment-processor-compare/" class="group flex flex-col border border-violet-200 dark:border-violet-800 bg-violet-50 dark:bg-violet-950 rounded-xl p-5 hover:border-violet-400 dark:hover:border-violet-600 hover:shadow-md transition-all">
      <div class="text-2xl mb-2">⚡</div>
      <h2 class="font-semibold text-gray-900 dark:text-gray-100 mb-1 group-hover:text-violet-700 dark:group-hover:text-violet-400 transition-colors">Payment Processors</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 flex-1">Shopify Payments vs Stripe vs PayPal vs 5 others. True total cost including the hidden Shopify transaction fee.</p>
    </a>
    <a href="/ltv-cac-calculator/" class="group flex flex-col border border-teal-200 dark:border-teal-800 bg-teal-50 dark:bg-teal-950 rounded-xl p-5 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all">
      <div class="text-2xl mb-2">♾️</div>
      <h2 class="font-semibold text-gray-900 dark:text-gray-100 mb-1 group-hover:text-teal-700 dark:group-hover:text-teal-400 transition-colors">LTV:CAC Calculator</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 flex-1">Customer Lifetime Value vs Acquisition Cost. Ratio benchmark, payback period, and improvement playbook.</p>
    </a>
    <a href="/cart-abandonment-calculator/" class="group flex flex-col border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-950 rounded-xl p-5 hover:border-amber-400 dark:hover:border-amber-600 hover:shadow-md transition-all">
      <div class="text-2xl mb-2">🛒</div>
      <h2 class="font-semibold text-gray-900 dark:text-gray-100 mb-1 group-hover:text-amber-700 dark:group-hover:text-amber-400 transition-colors">Cart Abandonment</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 flex-1">Monthly lost revenue + ROI of email, SMS, and retargeting recovery. Industry benchmarks by category.</p>
    </a>
    <a href="/app-stack-cost-auditor/" class="group flex flex-col border border-rose-200 dark:border-rose-800 bg-rose-50 dark:bg-rose-950 rounded-xl p-5 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all">
      <div class="text-2xl mb-2">🧮</div>
      <h2 class="font-semibold text-gray-900 dark:text-gray-100 mb-1 group-hover:text-rose-700 dark:group-hover:text-rose-400 transition-colors">App Stack Auditor</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 flex-1">30+ preset apps across 10 categories. See total monthly spend vs revenue benchmarks. Find what to cut.</p>
    </a>
  </div>

  <!-- Divider: Shipping & Utility tools -->
  <div class="border-t border-gray-200 dark:border-gray-700 pt-7 mb-4">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4">Quick Calculators</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <a href="/profit-margin/" class="flex items-center gap-2 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-blue-400 dark:hover:border-blue-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all text-sm">
        <span class="text-lg">💰</span>
        <span class="font-medium text-gray-800 dark:text-gray-200">Profit Margin</span>
      </a>
      <a href="/break-even/" class="flex items-center gap-2 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-blue-400 dark:hover:border-blue-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all text-sm">
        <span class="text-lg">⚖️</span>
        <span class="font-medium text-gray-800 dark:text-gray-200">Break-Even</span>
      </a>
      <a href="/free-shipping-threshold/" class="flex items-center gap-2 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-blue-400 dark:hover:border-blue-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all text-sm">
        <span class="text-lg">🚚</span>
        <span class="font-medium text-gray-800 dark:text-gray-200">Free Shipping</span>
      </a>
      <a href="/shipping/" class="flex items-center gap-2 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-blue-400 dark:hover:border-blue-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all text-sm">
        <span class="text-lg">🗺️</span>
        <span class="font-medium text-gray-800 dark:text-gray-200">Rates by City</span>
      </a>
      <a href="/china-shipping/" class="flex items-center gap-2 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-blue-400 dark:hover:border-blue-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all text-sm">
        <span class="text-lg">🇨🇳</span>
        <span class="font-medium text-gray-800 dark:text-gray-200">China Shipping</span>
      </a>
      <a href="/shipping-calculator/" class="flex items-center gap-2 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-blue-400 dark:hover:border-blue-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all text-sm">
        <span class="text-lg">📦</span>
        <span class="font-medium text-gray-800 dark:text-gray-200">Rate Calculator</span>
      </a>
    </div>
  </div>

  <!-- Why these calculators -->
  <section class="mt-10 border-t border-gray-100 dark:border-gray-800 pt-8">
    <h2 class="text-2xl font-bold mb-4">Why Shopify Sellers Need These Calculators</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-4">
      Shopify's advertised fees are only part of the story. The platform charges transaction fees (0.5–2%) on every order if you don't use Shopify Payments, plus currency conversion fees, chargeback fees, and third-party app costs that compound each month. Most sellers don't know their true margins until they run the numbers.
    </p>
    <p class="text-gray-600 dark:text-gray-400 mb-4">
      These calculators give you the complete picture: the <a href="/shopify-hidden-fees-audit/" class="text-blue-600 hover:underline">Hidden Fees Audit</a> surfaces every charge category most dashboards hide, while the <a href="/shopify-profit-calculator/" class="text-blue-600 hover:underline">Real Profit Calculator</a> builds a full monthly P&amp;L — revenue minus COGS, fees, marketing, apps, and returns — so you know exactly where every dollar goes.
    </p>
    <p class="text-gray-600 dark:text-gray-400">
      Unlike generic spreadsheet templates, each tool uses 2026 Shopify rates and includes sensitivity tables, so you can model "what if I upgrade to Advanced?" or "what if ROAS drops to 1.5x?" before it happens.
    </p>
  </section>

  <!-- How each calculator helps -->
  <section class="mt-8">
    <h2 class="text-2xl font-bold mb-5">How Each Calculator Helps You</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
        <h3 class="font-semibold mb-1">Real Profit Calculator</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Full P&amp;L breakdown — revenue, COGS, Shopify fees, app costs, marketing, returns. Shows the exact percentage each cost category takes.</p>
      </div>
      <div class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
        <h3 class="font-semibold mb-1">Hidden Fees Audit</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">5-step audit of every Shopify charge: transaction fees, currency conversion, chargeback reserve, app subscriptions, theme licensing.</p>
      </div>
      <div class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
        <h3 class="font-semibold mb-1">Breakeven ROAS Calculator</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Enter your margin and ad costs to find the minimum ROAS required to stay profitable — with per-channel breakdowns for Meta, Google, and TikTok.</p>
      </div>
      <div class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
        <h3 class="font-semibold mb-1">Plan Comparison Tool</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Compares Basic, Shopify, Advanced, and Plus at your revenue level. Shows exact monthly savings and the break-even point for upgrading.</p>
      </div>
      <div class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
        <h3 class="font-semibold mb-1">Payment Processor Comparison</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Shopify Payments vs Stripe vs PayPal — true total cost including the hidden Shopify transaction fee on third-party processors.</p>
      </div>
      <div class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
        <h3 class="font-semibold mb-1">App Stack Auditor</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">30+ preset apps across 10 categories. See total monthly app spend vs revenue benchmarks and find what to cut or consolidate.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mt-8 mb-4">
    <h2 class="text-2xl font-bold mb-5">Frequently Asked Questions</h2>
    <div class="space-y-4">
      <details class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
        <summary class="font-semibold cursor-pointer">What fees does Shopify charge that most sellers miss?</summary>
        <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">The most commonly missed fees are the transaction fee (0.5–2% on orders when not using Shopify Payments), currency conversion markup (1.5%), chargeback handling fees ($15 per dispute), and third-party app costs that add up to $100–$400/month for most mid-size stores.</p>
      </details>
      <details class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
        <summary class="font-semibold cursor-pointer">How is the Shopify profit calculator different from Shopify's own analytics?</summary>
        <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">Shopify Analytics shows revenue and basic gross profit. It doesn't subtract platform fees, app costs, marketing spend, or returns. The Real Profit Calculator builds a complete P&amp;L so you see net profit, not just gross margin.</p>
      </details>
      <details class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
        <summary class="font-semibold cursor-pointer">Are these calculators free? Do I need to create an account?</summary>
        <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">All 8 calculators are completely free with no signup required. Your data is processed in your browser and is never stored or shared.</p>
      </details>
      <details class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
        <summary class="font-semibold cursor-pointer">When should I upgrade from Basic to the Shopify plan?</summary>
        <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">The break-even point is typically around $35,000–$40,000/month in revenue, where the lower transaction fee (1% → 0.5%) saves more than the $39 monthly plan upgrade. Use the <a href="/shopify-plan-comparison/" class="text-blue-600 hover:underline">Plan Comparison tool</a> with your actual numbers to find your exact threshold.</p>
      </details>
    </div>
  </section>

  <!-- Trust bar -->
  <div class="mt-8 flex flex-wrap gap-6 justify-center text-sm text-gray-400 dark:text-gray-500 border-t border-gray-100 dark:border-gray-800 pt-6">
    <span>✓ No signup required</span>
    <span>✓ 2026 rates</span>
    <span>✓ Works on mobile</span>
    <span>✓ Free forever</span>
  </div>
</Base>
