---
import Base from '../layouts/Base.astro';
---
<Base
  title="Shopify Shipping Calculator — Free Tools for Sellers"
  description="Free calculators for Shopify sellers: shipping rates, profit margins, break-even analysis. No signup required."
>
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold mb-4">Free Shopify Calculator Tools</h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Quick, accurate calculators to help Shopify sellers price products, calculate shipping costs,
      and maximize profit margins.
    </p>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
    <a href="/shipping/" class="block border border-blue-200 bg-blue-50 rounded-xl p-6 hover:shadow-md transition">
      <div class="text-xs font-medium text-blue-600 uppercase tracking-wide mb-1">New — 280+ Cities</div>
      <h2 class="text-xl font-semibold mb-2">Shipping Rates by City</h2>
      <p class="text-gray-600 text-sm">Compare USPS, UPS, FedEx, and DHL rates from any US city to any destination. All 50 states covered.</p>
    </a>
    <a href="/china-shipping/" class="block border border-purple-200 bg-purple-50 rounded-xl p-6 hover:shadow-md transition">
      <div class="text-xs font-medium text-purple-600 uppercase tracking-wide mb-1">New — 50 Countries</div>
      <h2 class="text-xl font-semibold mb-2">China Shipping Rates</h2>
      <p class="text-gray-600 text-sm">ePacket, DHL, FedEx International rates from China to 50+ countries. 2026 rates.</p>
    </a>
    <a href="/shipping-calculator/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">Shipping Rate Calculator</h2>
      <p class="text-gray-600 text-sm">Estimate USPS, UPS, and FedEx shipping costs by weight and destination zip code.</p>
    </a>
    <a href="/profit-margin/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">Profit Margin Calculator</h2>
      <p class="text-gray-600 text-sm">Calculate net profit after Shopify fees, payment processing, COGS, and shipping.</p>
    </a>
    <a href="/break-even/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">Break-Even Calculator</h2>
      <p class="text-gray-600 text-sm">Find the minimum units you need to sell to cover your fixed and variable costs.</p>
    </a>
    <a href="/free-shipping-threshold/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">Free Shipping Threshold Calculator</h2>
      <p class="text-gray-600 text-sm">Optimal free shipping threshold that boosts AOV without eating your margin.</p>
    </a>
  </section>
</Base>
