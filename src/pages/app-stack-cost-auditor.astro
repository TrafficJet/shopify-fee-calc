        ]
      },
      { id: 'subscriptions', name: 'Subscriptions', icon: '🔁', roi: 'High ROI (if you sell subs)',
        apps: [
          { id: 'recharge',  name: 'ReCharge',           cost: 99 },
          { id: 'seal_subs', name: 'Seal Subscriptions', cost: 0  },
          { id: 'bold_subs', name: 'Bold Subscriptions', cost: 49 },
        ]
      },
    ];

    // state: { appId: cost | null } (null = not selected, number = active with cost)
    const state = {};
    const customApps = []; // { id, name, cost }
    let customCounter = 0;

    function fmt(n) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); }

    function getTotalByCategory() {
      const byCategory = {};
      APP_CATEGORIES.forEach(cat => {
        let sum = 0;
        cat.apps.forEach(app => {
          const cost = state[app.id];
          if (cost != null) sum += cost;
        });
        byCategory[cat.id] = { name: cat.name, icon: cat.icon, roi: cat.roi, total: sum };
      });
      // custom
      const customSum = customApps.reduce((s, a) => s + a.cost, 0);
      if (customSum > 0) byCategory['custom'] = { name: 'Custom Apps', icon: '⚙️', roi: '', total: customSum };
      return byCategory;
    }

    function updateSummary() {
      const byCategory = getTotalByCategory();
      const total = Object.values(byCategory).reduce((s, c) => s + c.total, 0);
      const revenue = parseFloat(document.getElementById('revenue').value) || 0;
      const pct = revenue > 0 ? (total / revenue * 100) : 0;
      const count = Object.values(state).filter(v => v != null).length + customApps.length;

      document.getElementById('totalCost').textContent = fmt(total);
      document.getElementById('annualCost').textContent = fmt(total * 12);
      document.getElementById('appCount').textContent = count;

      const pctEl = document.getElementById('pctRevenue');
      pctEl.textContent = pct.toFixed(1) + '%';
      pctEl.className = 'text-2xl font-bold ' + (pct > 5 ? 'text-red-600 dark:text-red-400' : pct > 3 ? 'text-yellow-600 dark:text-yellow-400' : 'text-green-600 dark:text-green-400');

      // Verdict
      const verdictEl = document.getElementById('verdict');
      if (count === 0) { verdictEl.classList.add('hidden'); return; }
      let msg, cls;
      if (pct <= 2) { msg = `✅ Healthy — app spend is ${pct.toFixed(1)}% of revenue (target: ≤ 2–3%). Your stack is lean.`; cls = 'border-green-300 dark:border-green-700 bg-green-50 dark:bg-green-950 text-green-700 dark:text-green-400'; }
      else if (pct <= 4) { msg = `⚠️ Moderate — app spend is ${pct.toFixed(1)}% of revenue. Acceptable but review low-ROI categories.`; cls = 'border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-950 text-yellow-700 dark:text-yellow-400'; }
      else { msg = `🔴 High — app spend is ${pct.toFixed(1)}% of revenue (target: ≤ 3%). Cut or consolidate low-ROI apps to save ${fmt((total - revenue * 0.03) * 12)}/yr.`; cls = 'border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-950 text-red-700 dark:text-red-400'; }
      verdictEl.className = `rounded-xl p-4 mb-6 border-2 text-sm font-medium ${cls}`;
      verdictEl.textContent = msg;
      verdictEl.classList.remove('hidden');

      // Category chart
      const maxCost = Math.max(...Object.values(byCategory).map(c => c.total), 1);
      document.getElementById('categoryChart').innerHTML = Object.values(byCategory)
        .filter(c => c.total > 0)
        .sort((a, b) => b.total - a.total)
        .map(c => {
          const w = Math.round(c.total / maxCost * 100);
          return `<div class="flex items-center gap-3">
            <div class="w-36 text-xs text-gray-600 dark:text-gray-400 truncate">${c.icon} ${c.name}</div>
            <div class="flex-1 bg-gray-100 dark:bg-gray-800 rounded-full h-4 relative">
              <div class="bg-blue-500 dark:bg-blue-600 h-4 rounded-full transition-all" style="width:${w}%"></div>
            </div>
            <div class="w-16 text-xs font-semibold text-right text-gray-800 dark:text-gray-200">${fmt(c.total)}/mo</div>
          </div>`;
        }).join('') || '<p class="text-sm text-gray-400">No apps selected yet.</p>';
    }

    function renderCategories() {
      const el = document.getElementById('categoryList');
      el.innerHTML = APP_CATEGORIES.map(cat => {
        const roiColor = cat.roi.startsWith('High') ? 'text-green-600 dark:text-green-400' :
                         cat.roi.startsWith('Medium') ? 'text-yellow-600 dark:text-yellow-400' :
                         'text-orange-600 dark:text-orange-400';
        const appsHtml = cat.apps.map(app => {
          const isActive = state[app.id] != null;
          const cost = state[app.id] ?? app.cost;
          return `<div class="flex items-center gap-3 py-2 border-b border-gray-100 dark:border-gray-800 last:border-0">
            <input type="checkbox" id="chk_${app.id}" data-id="${app.id}" ${isActive ? 'checked' : ''}
              class="w-4 h-4 accent-blue-600 cursor-pointer flex-shrink-0" />
            <label for="chk_${app.id}" class="flex-1 text-sm text-gray-800 dark:text-gray-200 cursor-pointer">${app.name}</label>
            <span class="text-xs text-gray-400 mr-1">$/mo</span>
            <input type="number" id="cost_${app.id}" value="${cost}" min="0" step="1"
              class="w-20 border border-gray-200 dark:border-gray-700 rounded px-2 py-1 text-sm bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-1 focus:ring-blue-500 ${!isActive ? 'opacity-40' : ''}"
              ${!isActive ? 'disabled' : ''} data-id="${app.id}" />
          </div>`;
        }).join('');

        return `<div class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
          <div class="bg-gray-50 dark:bg-gray-800 px-5 py-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="text-lg">${cat.icon}</span>
              <span class="font-semibold text-gray-900 dark:text-gray-100">${cat.name}</span>
            </div>
            <span class="text-xs font-medium ${roiColor}">${cat.roi}</span>
          </div>
          <div class="px-5 py-1">${appsHtml}</div>
        </div>`;
      }).join('');

      // Wire checkboxes
      document.querySelectorAll('input[type=checkbox]').forEach(chk => {
        chk.addEventListener('change', () => {
          const id = chk.dataset.id;
          const costInput = document.getElementById('cost_' + id);
          if (chk.checked) {
            state[id] = parseFloat(costInput.value) || 0;
            costInput.disabled = false;
            costInput.classList.remove('opacity-40');
          } else {
            state[id] = null;
            costInput.disabled = true;
            costInput.classList.add('opacity-40');
          }
          updateSummary();
        });
      });

      // Wire cost inputs
      document.querySelectorAll('input[type=number][data-id]').forEach(inp => {
        inp.addEventListener('input', () => {
          const id = inp.dataset.id;
          if (state[id] != null) {
            state[id] = parseFloat(inp.value) || 0;
            updateSummary();
          }
        });
      });
    }

    function renderCustomApps() {
      document.getElementById('customApps').innerHTML = customApps.map((a, i) =>
        `<div class="flex items-center gap-3 text-sm">
          <span class="text-gray-700 dark:text-gray-300 flex-1">${a.name}</span>
          <span class="font-semibold text-gray-900 dark:text-gray-100">$${a.cost}/mo</span>
          <button data-idx="${i}" class="remove-custom text-red-500 hover:text-red-700 text-xs px-2 py-0.5 border border-red-200 dark:border-red-800 rounded">✕</button>
        </div>`
      ).join('');

      document.querySelectorAll('.remove-custom').forEach(btn => {
        btn.addEventListener('click', () => {
          customApps.splice(parseInt(btn.dataset.idx), 1);
          renderCustomApps();
          updateSummary();
        });
      });
    }

    document.getElementById('addCustomBtn').addEventListener('click', () => {
      const name = document.getElementById('customName').value.trim();
      const cost = parseFloat(document.getElementById('customCost').value) || 0;
      if (!name) return;
      customApps.push({ id: 'custom_' + (++customCounter), name, cost });
      document.getElementById('customName').value = '';
      document.getElementById('customCost').value = '';
      renderCustomApps();
      updateSummary();
    });

    document.getElementById('revenue').addEventListener('input', updateSummary);

    renderCategories();
    updateSummary();
  </script>
</Base>
