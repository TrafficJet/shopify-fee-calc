---
import Base from '../layouts/Base.astro';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much should I spend on Shopify apps per month?",
      "acceptedAnswer": { "@type": "Answer", "text": "A healthy Shopify app budget depends on revenue stage. Early stores (<$10K/mo) should target under 3–5% of revenue in apps — roughly $300–$500/mo maximum. Mid-size stores ($10K–$100K/mo) typically spend 2–4% ($200–$4,000). High-volume stores ($100K+/mo) often spend 1–2% because fixed-cost apps dilute as a percentage. If your app spend exceeds 5% of revenue, audit each app for measurable ROI." } },
    { "@type": "Question", "name": "Which Shopify apps are worth the money?",
      "acceptedAnswer": { "@type": "Answer", "text": "The highest-ROI app categories for most Shopify stores are: (1) Email marketing — Klaviyo/Omnisend typically returns $40–$80 per dollar spent via automated flows; (2) Reviews — Judge.me or Stamped increase conversion 10–20%; (3) Upsell apps — ReConvert and similar return 5–15× their cost in added AOV. Low-ROI categories to audit: page builders (replace with Shopify's native sections), redundant analytics tools, and apps that duplicate native Shopify features." } },
    { "@type": "Question", "name": "How do I find and cancel unused Shopify apps?",
      "acceptedAnswer": { "@type": "Answer", "text": "In your Shopify admin, go to Apps → scroll to see all installed apps. Check the billing date for each — apps billing monthly you rarely open are candidates for removal. Also check Settings → Billing → Bills to see the exact app charges on your last invoice. Uninstalling an app cancels future charges immediately; Shopify doesn't prorate refunds for the current billing period." } },
    { "@type": "Question", "name": "What is a good alternative to Klaviyo for Shopify email marketing?",
      "acceptedAnswer": { "@type": "Answer", "text": "Omnisend ($16–$59/mo) is the best alternative at small-mid volume — it includes SMS, push notifications, and similar automation at lower cost. Shopify Email (built-in, $1/1,000 emails) works for basic campaigns. Drip and ActiveCampaign work well for stores needing advanced segmentation. Klaviyo's pricing scales with contacts — if you're on the $150+/mo tier, audit whether the advanced predictive features are driving measurable lift." } },
    { "@type": "Question", "name": "Should I pay for a Shopify page builder like Shogun or PageFly?",
      "acceptedAnswer": { "@type": "Answer", "text": "For most stores, no. Shopify's native theme editor with Online Store 2.0 sections covers 80–90% of landing page needs. Shogun ($39–$149/mo) and PageFly ($29–$99/mo) make sense if you run frequent promotional campaigns with unique layouts, or if you have a non-technical team that needs a visual editor. Before paying, check if your theme has a metafield-based section approach that covers your needs." } },
    { "@type": "Question", "name": "Are Shopify app costs tax deductible?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Shopify app subscription fees are business expenses deductible as software/SaaS costs. Keep your Shopify billing statements as records. The total annual app spend (use this auditor to calculate it) can be deducted from business income. Consult a tax professional for your specific jurisdiction." } },
  ]
});

const appSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Shopify App Stack Cost Auditor",
  "description": "Audit your entire Shopify app stack costs. Select apps you use, enter monthly costs, and see total spend vs revenue benchmarks. Find which apps to keep, optimize, or cut. Free 2026.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "url": "https://shopify-fee-calc.com/app-stack-cost-auditor/"
});

const faqs = [
  { q: "How much should I spend on Shopify apps per month?",
    a: "A healthy app budget: early stores (<$10K/mo revenue) should target under 3–5% of revenue, roughly $300–500/mo max. Mid-size stores ($10K–$100K/mo) typically spend 2–4%. High-volume stores ($100K+/mo) often spend 1–2% since fixed app costs dilute with scale. If app spend exceeds 5% of revenue, audit each app for measurable ROI." },
  { q: "Which Shopify apps are worth the money?",
    a: "Highest-ROI categories: (1) Email marketing — Klaviyo/Omnisend typically returns $40–80 per dollar spent via automated flows; (2) Reviews — Judge.me or Stamped increase conversion 10–20%; (3) Upsell apps — return 5–15× their cost in added AOV. Low-ROI candidates to audit: page builders (replace with native sections), redundant analytics, and apps duplicating built-in Shopify features." },
  { q: "How do I find and cancel unused Shopify apps?",
    a: "Shopify Admin → Apps → scroll all installed apps. Check Settings → Billing → Bills to see exact app charges on your last invoice. Uninstalling cancels future charges immediately. Shopify doesn't prorate refunds for the current billing period." },
  { q: "What is a good alternative to Klaviyo for Shopify?",
    a: "Omnisend ($16–59/mo) — SMS + email + push at lower cost. Shopify Email (built-in, $1/1,000 emails) for basic campaigns. Drip/ActiveCampaign for advanced segmentation. If on Klaviyo $150+/mo tier, audit whether predictive features are driving measurable lift vs cheaper tiers." },
  { q: "Should I pay for a Shopify page builder?",
    a: "For most stores, no. Shopify's native Online Store 2.0 editor covers 80–90% of needs. Shogun ($39–149/mo) or PageFly ($29–99/mo) make sense if you run frequent campaigns with unique layouts or have non-technical teams. Check your theme's metafield-based sections before paying." },
  { q: "Are Shopify app costs tax deductible?",
    a: "Yes — app subscription fees are business expenses deductible as software/SaaS costs. Your annual total from this auditor can be deducted from business income. Consult a tax professional for your specific jurisdiction." },
];

