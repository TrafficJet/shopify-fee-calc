---
import Base from '../layouts/Base.astro';
---
<Base title="About ShopifyCalc" description="Free Shopify calculators and guides for e-commerce sellers.">
  <div class="max-w-3xl mx-auto prose prose-blue prose-lg dark:prose-invert">
    <h1>About ShopifyCalc</h1>
    <p>ShopifyCalc is a free tool suite for Shopify merchants — shipping calculators, profit margin tools, break-even analysis, and expert guides.</p>
    <p>Built by e-commerce veterans after years of working with Shopify stores of all sizes.</p>
    <p>Questions? <a href="mailto:hello@shopify-fee-calc.com">hello@shopify-fee-calc.com</a></p>
  </div>
</Base>
