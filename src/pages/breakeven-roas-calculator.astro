  <style>
    .tip {
      display: inline-flex; align-items: center; justify-content: center;
      width: 14px; height: 14px; border-radius: 50%;
      font-size: 9px; font-weight: 700; font-style: normal;
      background: #d1d5db; color: #374151; cursor: help;
      vertical-align: middle; margin-left: 3px;
    }
    :global(.dark) .tip { background: #374151; color: #d1d5db; }
  </style>

  <script>
  const PLANS: Record<string, { monthly: number; rate: number; perTxn: number; penalty: number }> = {
    basic:    { monthly: 39,   rate: 0.029, perTxn: 0.30, penalty: 0.02 },
    shopify:  { monthly: 105,  rate: 0.027, perTxn: 0.30, penalty: 0.01 },
    advanced: { monthly: 399,  rate: 0.025, perTxn: 0.30, penalty: 0.005 },
    plus:     { monthly: 2300, rate: 0.018, perTxn: 0.30, penalty: 0.0015 },
  };
  const PROCS: Record<string, { rate: number | null; perTxn: number | null; penalty: boolean }> = {
    shopify: { rate: null,   perTxn: null,  penalty: false },
    stripe:  { rate: 0.029,  perTxn: 0.30,  penalty: true },
    paypal:  { rate: 0.0349, perTxn: 0.49,  penalty: true },
  };

  let plan = 'basic', proc = 'shopify';

  const ge = (id: string) => document.getElementById(id) as HTMLElement;
  const gv = (id: string) => parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  const fmt = (n: number) => '$' + Math.abs(n).toLocaleString('en-US', { maximumFractionDigits: 0 });
  const fmtS = (n: number) => (n < 0 ? '−' : '+') + fmt(n);

  // COGS range/number sync
  const cogsRange = document.getElementById('inp-cogs-range') as HTMLInputElement;
  const cogsNum   = document.getElementById('inp-cogs') as HTMLInputElement;
  cogsRange.addEventListener('input', () => { cogsNum.value = cogsRange.value; recalc(); });
  cogsNum.addEventListener('input',   () => { cogsRange.value = cogsNum.value; recalc(); });

  // Plan buttons
  function activatePlan(p: string) {
    plan = p;
    document.querySelectorAll<HTMLElement>('.plan-btn').forEach(btn => {
      const on = btn.dataset.plan === p;
      btn.className = on
        ? 'plan-btn border-2 border-blue-600 dark:border-blue-500 bg-blue-50 dark:bg-blue-950 rounded-xl p-3 text-left transition'
        : 'plan-btn border dark:border-gray-600 rounded-xl p-3 text-left transition hover:border-blue-400';
    });
    const penalty = PLANS[p].penalty;
    const lp = document.getElementById('label-penalty');
    const lpp = document.getElementById('label-penalty-pp');
    if (lp) lp.textContent = `+${(penalty * 100)}% penalty`;
    if (lpp) lpp.textContent = `+${(penalty * 100)}% penalty`;
  }
  document.querySelectorAll<HTMLElement>('.plan-btn').forEach(btn =>
    btn.addEventListener('click', () => { activatePlan(btn.dataset.plan!); recalc(); })
  );

  // Processor buttons
  function activateProc(p: string) {
    proc = p;
    document.querySelectorAll<HTMLElement>('.proc-btn').forEach(btn => {
      const on = btn.dataset.proc === p;
      btn.className = on
        ? 'proc-btn w-full text-left border-2 border-blue-600 dark:border-blue-500 bg-blue-50 dark:bg-blue-950 rounded-xl px-4 py-3 transition'
        : 'proc-btn w-full text-left border dark:border-gray-600 rounded-xl px-4 py-3 transition hover:border-blue-400';
    });
  }
  document.querySelectorAll<HTMLElement>('.proc-btn').forEach(btn =>
    btn.addEventListener('click', () => { activateProc(btn.dataset.proc!); recalc(); })
  );

  // Channel breakdown toggle
  let channelOpen = false;
  document.getElementById('channel-toggle')!.addEventListener('click', () => {
    channelOpen = !channelOpen;
    document.getElementById('channel-inputs')!.classList.toggle('hidden', !channelOpen);
    document.getElementById('channel-chevron')!.style.transform = channelOpen ? 'rotate(180deg)' : '';
  });
  ['inp-meta','inp-google','inp-tiktok','inp-other-ch'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', () => {
      const total = ['inp-meta','inp-google','inp-tiktok','inp-other-ch'].reduce((s,i) => s + gv(i), 0);
      (document.getElementById('inp-spend') as HTMLInputElement).value = String(total);
      ge('channel-total').textContent = fmt(total);
      recalc();
    });
  });

  function calcMetrics(roas: number, adSpend: number, cm: number, fixedCosts: number) {
    const revenue = roas * adSpend;
    const net = revenue * cm - fixedCosts - adSpend;
    const margin = revenue > 0 ? (net / revenue * 100) : 0;
    return { revenue, net, margin };
  }

  function recalc() {
    const adSpend = gv('inp-spend');
    const aov     = Math.max(gv('inp-aov'), 1);
    const cogsPct = parseFloat(cogsNum.value) / 100;
    const apps    = gv('inp-apps');
    const other   = gv('inp-other');

    const pl = PLANS[plan];
    const pr = PROCS[proc];
    const payRate   = pr.rate  ?? pl.rate;
    const payPerTxn = pr.perTxn ?? pl.perTxn;
    const penaltyRate = pr.penalty ? pl.penalty : 0;

    // Contribution margin
    const cm = 1 - cogsPct - payRate - payPerTxn / aov - penaltyRate;
    const fixedCosts = pl.monthly + apps + other;

    // Breakeven ROAS
    const beRoas = cm > 0 ? (adSpend + fixedCosts) / (adSpend * cm) : Infinity;

    // Update displays
    ge('d-gm').textContent = ((1 - cogsPct) * 100).toFixed(1) + '%';
    ge('res-roas').textContent = isFinite(beRoas) ? beRoas.toFixed(2) : '∞';
    ge('res-cm').textContent = (cm * 100).toFixed(1) + '%';
    const beRevenue = beRoas * adSpend;
    ge('res-rev-be').textContent = isFinite(beRevenue) ? fmt(beRevenue) : '—';

    // Benchmark
    const bench = ge('res-benchmark');
    if (!isFinite(beRoas) || beRoas > 8) {
      bench.textContent = '🔴 Very high breakeven — margin too thin for paid ads';
      bench.className = 'text-sm rounded-lg px-3 py-2 text-center font-medium bg-red-50 dark:bg-red-950 text-red-700 dark:text-red-400';
    } else if (beRoas > 4) {
      bench.textContent = '🟠 High breakeven — needs strong targeting to hit';
      bench.className = 'text-sm rounded-lg px-3 py-2 text-center font-medium bg-orange-50 dark:bg-orange-950 text-orange-700 dark:text-orange-400';
    } else if (beRoas > 2.5) {
      bench.textContent = '🟡 Moderate — achievable with good creatives';
      bench.className = 'text-sm rounded-lg px-3 py-2 text-center font-medium bg-yellow-50 dark:bg-yellow-950 text-yellow-700 dark:text-yellow-400';
    } else {
      bench.textContent = '🟢 Low breakeven — healthy margin for paid growth';
      bench.className = 'text-sm rounded-lg px-3 py-2 text-center font-medium bg-green-50 dark:bg-green-950 text-green-700 dark:text-green-400';
    }

    // Current ROAS checker
    const currentRoas = gv('inp-current-roas');
    const { revenue: curRev, net: curNet, margin: curMargin } = calcMetrics(currentRoas, adSpend, cm, fixedCosts);
    const isProfitable = curNet >= 0;
    const crEl = ge('current-roas-result');
    crEl.className = `text-sm rounded-lg px-4 py-3 space-y-1.5 ${isProfitable ? 'bg-green-50 dark:bg-green-950' : 'bg-red-50 dark:bg-red-950'}`;
    crEl.innerHTML = `
      <div class="flex justify-between"><span class="${isProfitable ? 'text-green-700 dark:text-green-400' : 'text-red-700 dark:text-red-400'}">Revenue</span><span class="font-semibold ${isProfitable ? 'text-green-800 dark:text-green-300' : 'text-red-800 dark:text-red-300'}">${fmt(curRev)}</span></div>
      <div class="flex justify-between"><span class="${isProfitable ? 'text-green-700 dark:text-green-400' : 'text-red-700 dark:text-red-400'}">Net Profit</span><span class="font-semibold ${isProfitable ? 'text-green-800 dark:text-green-300' : 'text-red-800 dark:text-red-300'}">${fmtS(curNet)}</span></div>
      <div class="flex justify-between"><span class="${isProfitable ? 'text-green-700 dark:text-green-400' : 'text-red-700 dark:text-red-400'}">Net Margin</span><span class="font-semibold ${isProfitable ? 'text-green-800 dark:text-green-300' : 'text-red-800 dark:text-red-300'}">${curMargin.toFixed(1)}%</span></div>
      <div class="pt-1 text-xs ${isProfitable ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400'} font-medium">${isProfitable ? `✓ Profitable — ${(currentRoas / beRoas).toFixed(2)}× above breakeven` : `✗ Below breakeven by ${(beRoas - currentRoas).toFixed(2)}× ROAS`}</div>
    `;

    // Sensitivity table
    const roasPoints = [1.0, 1.5, 2.0, 2.5, 3.0, 3.5, 4.0, 5.0];
    const tbody = ge('sensitivity-body');
    tbody.innerHTML = roasPoints.map(r => {
      const { revenue, net, margin } = calcMetrics(r, adSpend, cm, fixedCosts);
      const isBreakeven = Math.abs(r - beRoas) < 0.26;
      const isProfit = net >= 0;
      const rowClass = isBreakeven
        ? 'bg-blue-50 dark:bg-blue-950 border-b dark:border-gray-700'
        : 'border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/50';
      const valClass = isProfit ? 'text-green-600 dark:text-green-400' : 'text-red-500 dark:text-red-400';
      return `<tr class="${rowClass}">
        <td class="px-4 py-2 font-semibold ${isBreakeven ? 'text-blue-700 dark:text-blue-400' : 'text-gray-800 dark:text-gray-200'}">${r.toFixed(1)}×${isBreakeven ? ' ≈B/E' : ''}</td>
        <td class="px-4 py-2 text-right text-gray-600 dark:text-gray-400">${fmt(revenue)}</td>
        <td class="px-4 py-2 text-right font-medium ${valClass}">${fmtS(net)}</td>
        <td class="px-4 py-2 text-right ${valClass}">${margin.toFixed(1)}%</td>
      </tr>`;
    }).join('');
  }

  // Share link
  ge('share-btn').addEventListener('click', () => {
    const d = btoa(JSON.stringify({
      spend: (document.getElementById('inp-spend') as HTMLInputElement).value,
      aov:   (document.getElementById('inp-aov') as HTMLInputElement).value,
      cogs:  cogsNum.value,
      apps:  (document.getElementById('inp-apps') as HTMLInputElement).value,
      other: (document.getElementById('inp-other') as HTMLInputElement).value,
      cr:    (document.getElementById('inp-current-roas') as HTMLInputElement).value,
      plan, proc,
    }));
    navigator.clipboard.writeText(location.origin + location.pathname + '?d=' + d).then(() => {
      const c = ge('share-confirm');
      c.classList.remove('hidden');
      setTimeout(() => c.classList.add('hidden'), 2000);
    });
  });

  // Load from URL
  const urlParam = new URLSearchParams(location.search).get('d');
  if (urlParam) {
    try {
      const data = JSON.parse(atob(urlParam));
      const sv = (id: string, v: string | undefined) => { if (v) (document.getElementById(id) as HTMLInputElement).value = v; };
      sv('inp-spend', data.spend); sv('inp-aov', data.aov); sv('inp-apps', data.apps);
      sv('inp-other', data.other); sv('inp-current-roas', data.cr);
      if (data.cogs) { cogsNum.value = data.cogs; cogsRange.value = data.cogs; }
      if (data.plan) activatePlan(data.plan);
      if (data.proc) activateProc(data.proc);
    } catch {}
  }

  // Input listeners
  let debounce: ReturnType<typeof setTimeout>;
  document.querySelectorAll<HTMLInputElement>('#inp-spend,#inp-aov,#inp-apps,#inp-other,#inp-current-roas').forEach(el =>
    el.addEventListener('input', () => { clearTimeout(debounce); debounce = setTimeout(recalc, 150); })
  );
  document.getElementById('inp-current-roas')!.addEventListener('input', recalc);

  new MutationObserver(recalc).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  activatePlan('basic');
  activateProc('shopify');
  recalc();
  </script>
</Base>
